# GridOps Copilot — Frontend environment variables
# Copy to .env.local and adjust:
#   cp .env.local.example .env.local

# ── API mode ──────────────────────────────────────────────────────────────────
# false (default) → fixture/simulation mode; no backend required
# true  → live backend mode; all 4 services must be running
NEXT_PUBLIC_USE_LIVE_API=false

# ── Backend service URLs (only used when USE_LIVE_API=true) ──────────────────
NEXT_PUBLIC_INCIDENT_API_URL=http://localhost:8000
NEXT_PUBLIC_INGESTION_API_URL=http://localhost:8002
NEXT_PUBLIC_CREW_API_URL=http://localhost:8003
