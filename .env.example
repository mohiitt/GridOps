# ── TrueFoundry AI Gateway (preferred — provides cost/latency observability) ──
TFY_GATEWAY_BASE_URL=https://<org>.truefoundry.cloud/api/llm
TFY_API_KEY=your_truefoundry_api_key_here

# ── Direct OpenAI fallback (used when TFY vars above are not set) ─────────────
# OPENAI_API_KEY=sk-...

# ── Business settings ─────────────────────────────────────────────────────────
ENERGY_PRICE_PER_MWH=75
GRIDOPS_SEED=42

# ── Service URLs (used by ingestion service for inter-service calls) ──────────
ANOMALY_SERVICE_URL=http://localhost:8001
INGESTION_SERVICE_URL=http://localhost:8002
CREW_SERVICE_URL=http://localhost:8003
INCIDENT_API_URL=http://localhost:8000
